# Copy this file to ".env" and fill in your values.

# --- AI provider ---
# Which provider generates the appeal messages:
#   gemini    (free tier)  -> set GEMINI_API_KEY
#   groq      (free tier)  -> set GROQ_API_KEY
#   deepseek  (cheap,paid) -> set DEEPSEEK_API_KEY
#   openai    (paid)       -> set OPENAI_API_KEY
#   ollama    (free/local) -> run Ollama locally, no key needed
#   anthropic (paid)       -> set ANTHROPIC_API_KEY
# You can also set keys and turn on auto-fallback in the dashboard Settings.
AI_PROVIDER=gemini

# Leave AI_MODEL blank to use the provider's default model.
# Defaults: gemini=gemini-2.5-flash, groq=llama-3.3-70b-versatile,
#           deepseek=deepseek-chat, openai=gpt-4o-mini, ollama=llama3.1,
#           anthropic=claude-opus-4-8
AI_MODEL=

# Google Gemini (free): get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (free): get a key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI / ChatGPT (paid): get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek (very cheap, paid): get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic / Claude (paid): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama (local): defaults to http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# --- Your project system (the crawler logs in here) ---
PROJECTS_URL=https://sys.rcx18.com/projects

# --- Contact email rotation ---
# Email is built as:  {EMAIL_BASE}+{number}@{EMAIL_DOMAIN}
# where number = START_INDEX + case position (0-based crawl order).
# Example: EMAIL_BASE=abcd, START_INDEX=1  ->  abcd+1@gmail.com, abcd+2@gmail.com, ...
EMAIL_BASE=oudompanha1111
EMAIL_DOMAIN=gmail.com
START_INDEX=1
